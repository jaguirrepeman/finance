# =============================================================================
# webhook.env.example — Plantilla para el secreto del webhook de GitHub
#
# Copia este fichero a `webhook.env` (que está git-ignorado) y pon un secreto
# fuerte. El MISMO valor debe configurarse en:
#   GitHub repo → Settings → Webhooks → Secret
#
#   cp deploy/webhook.env.example deploy/webhook.env
#   # edita deploy/webhook.env  (o genera uno: openssl rand -hex 24)
#   chmod 600 deploy/webhook.env
#   sudo systemctl restart portfolio-webhook
#
# install_service.sh genera este fichero automáticamente si no existe.
# =============================================================================
WEBHOOK_SECRET=cambiame-por-un-secreto-fuerte
